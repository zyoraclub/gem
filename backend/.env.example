# Gmail IMAP for OTP fetching (REQUIRED)
# Get App Password: myaccount.google.com → Security → 2-Step Verification → App passwords
GMAIL_EMAIL=your-email@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Google OAuth Configuration (for production)
# Create OAuth 2.0 credentials at: https://console.cloud.google.com/apis/credentials
# Download as JSON and rename to client_secrets.json, or set these values:

GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/oauth/callback

# 2Captcha API Key (for captcha solving)
CAPTCHA_API_KEY=your_2captcha_api_key

# Database (SQLite by default)
DATABASE_URL=sqlite:///./gem_portal.db

# Server
HOST=0.0.0.0
PORT=8000
